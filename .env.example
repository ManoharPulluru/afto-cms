# Deployment identity (fallback slug lookup when BUSINESS_ID is unset)
STORE_SLUG=namastesupermarket
# UUID v7 for the tenant row in website_configs (set after npm run db:setup)
BUSINESS_ID=

# Azure PostgreSQL — websites-cms database
DB_HOST=
DB_USERNAME=
DB_PASSWORD=
DB_PORT=5432
DB_DATABASE_NAME=websites-cms
# Existing DB used only by db:setup to CREATE DATABASE (not used at runtime)
DB_BOOTSTRAP_DATABASE=afto_qa_latest
CMS_DB_NAME=websites-cms
DB_SSL=true

# Session signing for Studio login
STUDIO_SECRET=change-me-to-a-secure-random-string

# Backend API (customer OTP + future endpoints)
NEXT_PUBLIC_BACKEND_API_URL=https://qa3.getafto.com/backend/v1
# businessAccountId for customer OTP + WhatsApp templates
NEXT_PUBLIC_BUSINESS_ACCOUNT_ID=

# Server-only token for WhatsApp template APIs (token-wrapper)
AFTO_EXTERNAL_TOKEN=

# Optional Stripe (payment step — can also come from /payments/intent)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_STRIPE_ACCOUNT_ID=

# Multi-tenant local dev:
#   npm run dev        → namaste on :3000 (.env)
#   npm run dev:ajax   → ajax blank site on :3001 (.env.ajax)
#   npm run dev:ak     → animal kingdom on :3002 (.env.animalkingdom)
