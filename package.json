{
  "name": "afto-storefront",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:ajax": "dotenv -e .env.ajax -- next dev -p 3001",
    "dev:ak": "dotenv -e .env.animalkingdom -- next dev -p 3002",
    "db:seed:ak": "dotenv -e .env.animalkingdom -- tsx scripts/seed-business.ts --slug animalkingdom --name \"Animal Kingdom\" --blank --email kes_afto@yopmail.com --password kes_afto@yopmail.com",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:setup": "tsx scripts/db-setup.ts",
    "db:seed": "tsx scripts/seed-business.ts",
    "db:seed-components": "tsx scripts/seed-components.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@iconify/react": "^6.0.2",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "dotenv": "^17.4.2",
    "next": "15.3.9",
    "pg": "^8.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "15.3.9",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
